<%- include('./partials/header') %>

    <% if(success.length>0){ %>
        <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
            <span class="inline-block mt-1 mb-1 text-white">
                <%= success %>
            </span>
        </div>
        <% } %>

            <div class="w-full h-screen flex items-start px-20 py-10">
                <div class="w-[22%] flex h-screen flex-col items-start text-[1.3rem]">
                    <div class="flex items-center gap-2">
                        <h3>sort by</h3>
                        <form action="/shop">
                            <select class="border-[1px] px-2 py-1" name="sortby" id="">
                                <option value="popular">Popular</option>
                                <option value="newest">Newest</option>
                            </select>
                        </form>
                    </div>
                    <div class="flex flex-col mt-20">
                        <a class="block w-fit mb-2" href="/shop">New Collection</a>
                        <a class="block w-fit mb-2" href="/shop">All Products</a>
                        <a class="block w-fit mb-2" href="/shop/discounts">Discounted Products</a>
                    </div>
                    <div class="mt-32">
                        <h3 class="block w-fit mb-2" href="">Filter by :</h3>
                        <a class="block w-fit mb-2" href="/shop">Availability</a>
                        <a class="block w-fit mb-2" href="/shop/discounts">Discount</a>
                    </div>
                </div>
                <div class="w-[78%] flex flex-col gap-5 h-screen">
                    <div class="flex items-start flex-wrap gap-5">
                        <% products.forEach(function(product){ %>
                            <div class="w-[13rem]">
                                <div class="w-full h-52 flex items-center justify-center bg-[<%= product.bgcolor %>]">
                                    <img class="h-[11rem]"
                                        src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
                                </div>
                                <div
                                    class="flex justify-between bg-[<%= product.panelcolor %>] items-center px-4 py-4 text-[<%= product.textcolor %>]">
                                    <div>
                                        <h3>
                                            <%= product.name %>
                                        </h3>
                                        <div class="flex">
                                            <h4>₹ <%= product.price %>
                                            </h4>
                                            <% if(product.discount>0){ %>
                                                <div class="ml-2 rounded-3xl px-1.5 py-0.5 text-[0.8rem] text-[<%=product.panelcolor%>] bg-[<%=product.textcolor%>]">
                                                    -<%=product.discount%>%
                                                </div>
                                                <% } %>
                                        </div>

                                    </div>
                                    <a class="w-7 h-7 flex items-center justify-center rounded-full bg-white"
                                        href="/addtocart/<%= product._id %>">
                                        <i class="ri-add-line"></i>
                                    </a>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </div>
            <%- include('./partials/footer') %>