<%- include('./partials/header') %>
    <div class="w-full h-screen flex items-start px-20 py-10 gap-10">
        <div class="flex flex-wrap gap-7 pb-10">
        <% user.cart.forEach((product)=> { %>
            <div class="w-[45%] rounded-md overflow-hidden">
                <div class="w-full h-60 bg-[<%=product.bgcolor%>] flex justify-center items-center">
                    <img class="h-[12rem]" src="data:image/jpeg;base64, <%= product.image.toString('base64') %>" alt="">
                </div>
                <div class="w-full flex justify-between px-5 py-4 bg-[<%=product.panelcolor%>]">
                    <h3 class="text-2xl inline-block w-[10rem]"><%=product.name%></h3>
                    <div class="flex items-center gap-1">
                        <i class="cursor-pointer w-6 h-6 bg-white flex rounded-full items-center justify-center ri-add-line"></i>
                        <div class="px-1.5 py-0.5 rounded-md bg-white text-black">01</div>
                        <i class="cursor-pointer w-6 h-6 bg-white flex rounded-full items-center justify-center ri-subtract-line"></i>
                    </div>
                </div>
                <div class="flex text-white items-center justify-between px-5 py-3 bg-[<%=product.textcolor%>]">
                    <h4 class="text-lg">Net Total</h4>
                    <h2 class="text-lg">₹ <%=product.price%></h2>
                </div>
            
            </div>
        <% }) %>
        </div>
            <div class="w-[70%]">
                <h3 class="text-xl">Price Breakdown</h3>
                <div class="px-10 mt-5">
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Total MRP</h4>
                        <% var sum = 0; var discount = 0; %>
                        <% user.cart.forEach((product) => {sum += parseFloat(product.price); discount += parseFloat(product.discount?product.discount:0)}) %>
                        <h4>₹ <%=sum%></h4>
                    </div>
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Discount on MRP</h4>
                        <h4>₹ <%= discount %></h4>
                    </div>
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Platform Fee</h4>
                        <h4>₹ 20</h4>
                    </div>
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Shipping Fee</h4>
                        <h4>FREE</h4>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-black mt-10"></div>
                <div class="flex mt-5">
                    <h3 class="w-1/3 text-xl">Total Amount</h3>
                    <h3 class="font-semibold text-xl text-green-600">₹ <%=sum-discount-20%></h3>
                </div>
                <!-- <form action=""></form> -->
            </div>
    </div>
    <%- include('./partials/footer') %>