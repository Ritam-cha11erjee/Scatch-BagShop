<%- include('./partials/header') %>
    <div class="w-full h-screen flex items-start px-20 py-20">
        <div class="w-[22%] flex h-screen flex-col items-start">
            <div class="flex flex-col">
                <a class="block w-fit mb-2" href="">All Products</a>
                <a class="block w-fit mb-2" href="/owners/createproduct">Create new product</a>
            </div>
        </div>
        <div class="w-[78%] flex flex-col gap-5 h-screen">
            <a class="text-red-500" href="">Delete all</a>
            <div class="flex items-start flex-wrap gap-5 pb-10">
                        <% products.forEach(function(product){ %>
                            <div class="w-[13rem]">
                                <div class="w-full h-52 flex items-center justify-center bg-[<%= product.bgcolor %>]">
                                    <img class="h-[11rem]"
                                        src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
                                </div>
                                <div
                                    class="flex justify-between bg-[<%= product.panelcolor %>] items-center px-4 py-4 text-[<%= product.textcolor %>]">
                                    <div>
                                        <h3>
                                            <%= product.name %>
                                        </h3>
                                        <div class="flex">
                                            <h4>₹ <%= product.price %>
                                            </h4>
                                            <% if(product.discount>0){ %>
                                                <div class="ml-2 rounded-3xl px-1.5 py-0.5 text-[0.8rem] text-[<%=product.panelcolor%>] bg-[<%=product.textcolor%>]">
                                                    -<%=product.discount%>%
                                                </div>
                                                <% } %>
                                        </div>

                                    </div>
                                    <a class="w-7 h-7 flex items-center justify-center rounded-full bg-white"
                                        href="/addtocart/<%= product._id %>">
                                        <i class="ri-add-line"></i>
                                    </a>
                                </div>
                            </div>
                            <% }) %>
            </div>
        </div>
    </div>
    <%- include('./partials/footer') %>